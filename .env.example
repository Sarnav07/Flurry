# Yeti Trials backend environment template.
# Copy to `.env` and fill in real values. NEVER commit a populated `.env`
# or any real private keys / keystores (see .gitignore).

# ---------------------------------------------------------------------------
# Network selection
# ---------------------------------------------------------------------------
# Which Sui network to target. Selects the deployed.<network>.json artifact.
# One of: localnet | testnet
SUI_NETWORK=localnet
# Full node RPC URL for the selected network. Optional: leave blank to use the
# network default (localnet -> http://127.0.0.1:9000, testnet -> the default
# testnet fullnode). For testnet, set SUI_NETWORK=testnet; publish/init/
# lifecycle/smoke then target deployed.testnet.json automatically.
# localnet default: http://127.0.0.1:9000
SUI_RPC_URL=http://127.0.0.1:9000

# ---------------------------------------------------------------------------
# Published package
# ---------------------------------------------------------------------------
# Object ID of the published yeti_trials package. Populated by scripts/publish.ts
# (also written to deployed.<network>.json); leave blank before first publish.
PACKAGE_ID=

# ---------------------------------------------------------------------------
# Admin credentials (holds the AdminCap)
# ---------------------------------------------------------------------------
# Provide EITHER a raw private key OR a path to a Sui keystore file, not both.
# Placeholder only — do not commit a real key.
ADMIN_PRIVATE_KEY=
ADMIN_KEYSTORE_PATH=

# ---------------------------------------------------------------------------
# Oracle signer (Ed25519)
# ---------------------------------------------------------------------------
# Private key the orchestrator uses to sign attestations (raw 64-byte sign()).
# Placeholder only — do not commit a real key.
ORACLE_PRIVATE_KEY=
# Raw 32-byte Ed25519 public key (hex/base64) registered via add_signer.
ORACLE_PUBLIC_KEY=

# ---------------------------------------------------------------------------
# Sponsored transactions (zkLogin / sponsored-gas hooks) — placeholders
# ---------------------------------------------------------------------------
SPONSOR_PRIVATE_KEY=
SPONSOR_ADDRESS=
SPONSOR_ENABLED=false

# ---------------------------------------------------------------------------
# Active demo configuration (Genesis Frost)
# ---------------------------------------------------------------------------
ACTIVE_SEASON_ID=
ACTIVE_TRIAL_ID=

# ---------------------------------------------------------------------------
# Impact escrow verified recipients (one Sui address per faction)
# ---------------------------------------------------------------------------
IMPACT_RECIPIENT_GLACIERS=
IMPACT_RECIPIENT_AVALANCHE=
IMPACT_RECIPIENT_BLIZZARD=
IMPACT_RECIPIENT_THAW=

# ---------------------------------------------------------------------------
# Demo controls
# ---------------------------------------------------------------------------
# Guards POST /demo/reset. Must be "true" to allow clearing the in-memory store.
DEMO_MODE=false

# Human label of the active trial (display only; not serialized on-chain).
# Defaults to "Avalanche Testnet Proof" when unset.
ACTIVE_TRIAL_LABEL=

# Score delta an accepted demo attestation credits (u64). Default: 100.
DEMO_SCORE=
# Territory-power delta an accepted demo attestation credits (u64). Default: 50.
DEMO_TERRITORY_POWER=
# Attestation validity window in ms (expiry = issued + window). Default: 24h
# (86400000). Use a generous value on testnet to absorb real-clock latency.
ATTEST_EXPIRY_MS=

# Demo proof condition controls (orchestrator oracle).
# Comma-separated wallet addresses that satisfy the demo condition without
# owning a demo object (a CLEARLY-LABELED demo shortcut, never a prod trust
# source).
DEMO_ALLOWLIST=
# Optional Sui object TYPE the wallet must own to pass the demo condition.
DEMO_OBJECT_TYPE=
# Optional specific Sui object id the wallet must own to pass the demo condition.
DEMO_OBJECT_ID=

# ---------------------------------------------------------------------------
# Player credentials (optional; signs submit_proof as a distinct wallet)
# ---------------------------------------------------------------------------
# Optional. When unset, the demo falls back to the admin keypair as the player.
PLAYER_PRIVATE_KEY=
PLAYER_KEYSTORE_PATH=
PLAYER_KEYSTORE_INDEX=0

# ---------------------------------------------------------------------------
# Sponsor slot display metadata (optional; GET /config display only)
# ---------------------------------------------------------------------------
SPONSOR_NAME=
SPONSOR_ACTION_LABEL=

# ---------------------------------------------------------------------------
# Orchestrator server bind (optional)
# ---------------------------------------------------------------------------
# Port and host the Fastify orchestrator listens on. Defaults: 3000 / 0.0.0.0.
PORT=3000
HOST=0.0.0.0

# ---------------------------------------------------------------------------
# Smoke test (localnet) tuning (optional)
# ---------------------------------------------------------------------------
# Active-season window (ms) the localnet smoke harness opens. Must comfortably
# cover passport creation + submit + in-window replay. Default: 30000.
SMOKE_WINDOW_MS=30000
