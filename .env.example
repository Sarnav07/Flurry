# Yeti Trials backend environment template.
# Copy to `.env` and fill in real values. NEVER commit a populated `.env`
# or any real private keys / keystores (see .gitignore).

# ---------------------------------------------------------------------------
# Network selection
# ---------------------------------------------------------------------------
# Which Sui network to target. Selects the deployed.<network>.json artifact.
# One of: localnet | testnet
SUI_NETWORK=localnet
# Full node RPC URL for the selected network.
# localnet default: http://127.0.0.1:9000
SUI_RPC_URL=http://127.0.0.1:9000

# ---------------------------------------------------------------------------
# Published package
# ---------------------------------------------------------------------------
# Object ID of the published yeti_trials package. Populated by scripts/publish.ts
# (also written to deployed.<network>.json); leave blank before first publish.
PACKAGE_ID=

# ---------------------------------------------------------------------------
# Admin credentials (holds the AdminCap)
# ---------------------------------------------------------------------------
# Provide EITHER a raw private key OR a path to a Sui keystore file, not both.
# Placeholder only — do not commit a real key.
ADMIN_PRIVATE_KEY=
ADMIN_KEYSTORE_PATH=

# ---------------------------------------------------------------------------
# Oracle signer (Ed25519)
# ---------------------------------------------------------------------------
# Private key the orchestrator uses to sign attestations (raw 64-byte sign()).
# Placeholder only — do not commit a real key.
ORACLE_PRIVATE_KEY=
# Raw 32-byte Ed25519 public key (hex/base64) registered via add_signer.
ORACLE_PUBLIC_KEY=

# ---------------------------------------------------------------------------
# Sponsored transactions (zkLogin / sponsored-gas hooks) — placeholders
# ---------------------------------------------------------------------------
SPONSOR_PRIVATE_KEY=
SPONSOR_ADDRESS=
SPONSOR_ENABLED=false

# ---------------------------------------------------------------------------
# Active demo configuration (Genesis Frost)
# ---------------------------------------------------------------------------
ACTIVE_SEASON_ID=
ACTIVE_TRIAL_ID=

# ---------------------------------------------------------------------------
# Impact escrow verified recipients (one Sui address per faction)
# ---------------------------------------------------------------------------
IMPACT_RECIPIENT_GLACIERS=
IMPACT_RECIPIENT_AVALANCHE=
IMPACT_RECIPIENT_BLIZZARD=
IMPACT_RECIPIENT_THAW=

# ---------------------------------------------------------------------------
# Demo controls
# ---------------------------------------------------------------------------
# Guards POST /demo/reset. Must be "true" to allow clearing the in-memory store.
DEMO_MODE=false
