{
  "name": "yeti-trials-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Yeti Trials backend monorepo: Sui Move package, shared TS modules, orchestrator/demo-oracle, and lifecycle scripts.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "move:build": "sui move build --path contracts --build-env testnet",
    "move:test": "sui move test --path contracts --build-env testnet",
    "smoke": "pnpm --filter @yeti-trials/scripts run smoke"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "fast-check": "3.23.2",
    "tsx": "4.19.2",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  }
}
