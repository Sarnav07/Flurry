# Yeti Trials frontend environment template.
# Copy to `.env` and fill in values for your target backend. NEVER commit a
# populated `.env`. Only `VITE_`-prefixed variables are exposed to the browser
# (never a non-VITE build prefix). No package / object / season / trial id is
# ever set here: those are discovered at runtime from GET /config.

# ---------------------------------------------------------------------------
# Orchestrator (frontend API + demo oracle + chain reader)
# ---------------------------------------------------------------------------
# Base URL of the running orchestrator. Default dev port is 3000.
VITE_ORCHESTRATOR_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Sui network (display network of record comes from GET /health, not from here)
# ---------------------------------------------------------------------------
# One of: localnet | testnet
VITE_SUI_NETWORK=localnet
# Full node RPC URL. Leave blank to use the network default
# (localnet -> http://127.0.0.1:9000).
VITE_SUI_RPC_URL=http://127.0.0.1:9000

# ---------------------------------------------------------------------------
# Render / cinematic feature flags (all default off)
# ---------------------------------------------------------------------------
# Enable the lazy-loaded R3F 3D scene. When false, the premium 2.5D fallback
# render path is used. Default: false.
VITE_ENABLE_3D=false
# Enable the post-processing stack (only meaningful with the 3D path and a
# capable device). Default: false.
VITE_ENABLE_POST_FX=false

# ---------------------------------------------------------------------------
# Demo / onboarding feature flags (all default off)
# ---------------------------------------------------------------------------
# Surfaces demo-only affordances (e.g. the guarded reset surface). Default: false.
VITE_DEMO_MODE=false
# Enables the optional zkLogin onboarding + sponsored first-run path. The
# default and always-sufficient path is a standard wallet + direct submit.
# Default: false.
VITE_ENABLE_ZKLOGIN=false
