/// Reconstruct the known payload from its typed fields.
fun known_payload(): proof::ProofPayload {
    proof::build_payload(
        b"localnet",
        @0x1111111111111111111111111111111111111111111111111111111111111111,
        42, // season_id
        7, // trial_id
        1, // faction_id (Avalanche)
        @0x2222222222222222222222222222222222222222222222222222222222222222,
        @0x3333333333333333333333333333333333333333333333333333333333333333,
        b"Oracle-Attested Demo Proof",
        2, // provenance_tier (Oracle-Attested)
        1234, // score
        567, // territory_power
        1700000000000, // issued_ms
        1700000600000, // expiry_ms
        99, // nonce
        known_nullifier(),
    )
}

// Feature: yeti-trials-backend, Property 1: Signing-path byte-identity round-trip
//
// The Move-reconstructed Signed_Message bytes equal the TS-serialized bytes.
#[test]
fun byte_identity_matches_typescript() {
    let payload = known_payload();
    assert!(proof::signed_message_bytes(&payload) == known_signed_message(), 0);
    // The nullifier the Move side recomputes from the preimage matches too.
    let computed = proof::compute_nullifier(
        42,
        7,
        1,
        @0x2222222222222222222222222222222222222222222222222222222222222222,
        @0x3333333333333333333333333333333333333333333333333333333333333333,
        99,
    );
    assert!(computed == known_nullifier(), 1);
}

// Feature: yeti-trials-backend, Property 1: Signing-path byte-identity round-trip
//
// The genuine 64-byte Ed25519 signature verifies against the reconstructed
// message and the fixed public key.
#[test]
fun valid_signature_verifies_true() {
    let payload = known_payload();
    let sig = known_signature();
    let pk = known_pk();
    assert!(proof::verify_payload_signature(&payload, &sig, &pk), 0);
}

// Feature: yeti-trials-backend, Property 1: Signing-path byte-identity round-trip
//
// A single flipped bit in the SIGNATURE makes verification fail.
#[test]
fun flipped_signature_bit_verifies_false() {
    let payload = known_payload();
    let mut sig = known_signature();
    let b0 = *vector::borrow(&sig, 0);
    *vector::borrow_mut(&mut sig, 0) = b0 ^ 1u8;
    let pk = known_pk();
    assert!(!proof::verify_payload_signature(&payload, &sig, &pk), 0);
}

// Feature: yeti-trials-backend, Property 1: Signing-path byte-identity round-trip
//
// A single flipped bit in the MESSAGE makes verification fail.
#[test]
fun flipped_message_bit_verifies_false() {
    let mut msg = known_signed_message();
    let i = 20; // a byte inside the BCS body (past the 11-byte domain prefix)
    let b = *vector::borrow(&msg, i);
    *vector::borrow_mut(&mut msg, i) = b ^ 1u8;
    let sig = known_signature();
    let pk = known_pk();
    assert!(!ed25519::ed25519_verify(&sig, &pk, &msg), 0);
}

// Feature: yeti-trials-backend, Property 1: Signing-path byte-identity round-trip
//
// The abort-path helper aborts E_INVALID_SIGNATURE on a bad signature.
#[test]
#[expected_failure(abort_code = E_INVALID_SIGNATURE, location = yeti_trials::proof)]
fun assert_valid_signature_aborts_on_bad_sig() {
    let payload = known_payload();
    let mut sig = known_signature();
    let b0 = *vector::borrow(&sig, 0);
    *vector::borrow_mut(&mut sig, 0) = b0 ^ 1u8;
    let pk = known_pk();
    proof::assert_valid_signature(&payload, &sig, &pk);
}
