}

fun known_nullifier(): vector<u8> {
    vector[182, 17, 238, 7, 80, 64, 221, 96, 23, 96, 27, 149, 39, 152, 66, 47, 120, 224, 92, 191, 79, 40, 224, 187, 229, 100, 49, 101, 77, 38, 102, 27]
