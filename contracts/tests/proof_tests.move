/// Phase-2 hermetic known-vector test for the byte-identical TS↔Move signing
/// path.
///
/// Feature: yeti-trials-backend, Property 1: Signing-path byte-identity round-trip
///
/// A FIXED Ed25519 keypair (the deterministic conformance seed) signs a single
/// KNOWN `ProofPayload` in TypeScript; the signature, the serialized
/// `Signed_Message`, the nullifier, and the public key are checked in below.
/// This test reconstructs the same payload in Move and asserts:
///   * the Move-reconstructed `Signed_Message` bytes equal the TS bytes
///     (byte identity — Requirements 4.1, 4.2, 4.3, 4.6);
///   * the genuine 64-byte signature verifies (Requirements 4.4, 4.5);
///   * a single flipped bit in the message OR the signature makes verification
///     fail.
///
/// If byte identity ever breaks, compare `proof::payload_bcs_bytes(&payload)`
/// against the TS `serializeProofPayload(payload)` hex field-by-field; the most
/// likely culprit is a BigInt/number slip or a field-order mismatch.
#[test_only]
module yeti_trials::proof_tests;

use sui::ed25519;
use yeti_trials::proof;

// Abort code mirrored from `yeti_trials::constants` (private module const),
// kept in sync by value (E_INVALID_SIGNATURE = 7).
const E_INVALID_SIGNATURE: u64 = 7;

// --- Checked-in known vector (generated by the fixed conformance keypair) ---

