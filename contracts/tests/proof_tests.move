fun known_signed_message(): vector<u8> {
    vector[89, 101, 116, 105, 32, 84, 114, 105, 97, 108, 115, 8, 108, 111, 99, 97, 108, 110, 101, 116, 17, 17, 17, 17, 17, 17, 17, 17, 17, 17, 17, 17, 17, 17, 17, 17, 17, 17, 17, 17, 17, 17, 17, 17, 17, 17, 17, 17, 17, 17, 17, 17, 42, 0, 0, 0, 0, 0, 0, 0, 7, 0, 0, 0, 0, 0, 0, 0, 1, 34, 34, 34, 34, 34, 34, 34, 34, 34, 34, 34, 34, 34, 34, 34, 34, 34, 34, 34, 34, 34, 34, 34, 34, 34, 34, 34, 34, 34, 34, 34, 34, 51, 51, 51, 51, 51, 51, 51, 51, 51, 51, 51, 51, 51, 51, 51, 51, 51, 51, 51, 51, 51, 51, 51, 51, 51, 51, 51, 51, 51, 51, 51, 51, 26, 79, 114, 97, 99, 108, 101, 45, 65, 116, 116, 101, 115, 116, 101, 100, 32, 68, 101, 109, 111, 32, 80, 114, 111, 111, 102, 2, 210, 4, 0, 0, 0, 0, 0, 0, 55, 2, 0, 0, 0, 0, 0, 0, 0, 104, 229, 207, 139, 1, 0, 0, 192, 143, 238, 207, 139, 1, 0, 0, 99, 0, 0, 0, 0, 0, 0, 0, 32, 182, 17, 238, 7, 80, 64, 221, 96, 23, 96, 27, 149, 39, 152, 66, 47, 120, 224, 92, 191, 79, 40, 224, 187, 229, 100, 49, 101, 77, 38, 102, 27]
